import java.io.*;
import java.nio.file.*;
import java.security.MessageDigest;

public class FileIntegrityChecker {

    public static String calculateHash(String fileName) throws Exception {
        MessageDigest md = MessageDigest.getInstance("SHA-256");

        FileInputStream fis = new FileInputStream(fileName);
        byte[] buffer = new byte[4096];
        int bytesRead;

        while ((bytesRead = fis.read(buffer)) != -1) {
            md.update(buffer, 0, bytesRead);
        }

        fis.close();

        byte[] hashBytes = md.digest();

        StringBuilder sb = new StringBuilder();
        for (byte b : hashBytes) {
            sb.append(String.format("%02x", b));
        }

        return sb.toString();
    }

    public static void main(String[] args) {
        try {
            BufferedReader reader =
                    new BufferedReader(new InputStreamReader(System.in));

            System.out.print("Enter file name: ");
            String fileName = reader.readLine();

            String currentHash = calculateHash(fileName);

            String hashFile = fileName + ".hash";

            File file = new File(hashFile);

            if (!file.exists()) {

                Files.write(Paths.get(hashFile),
                        currentHash.getBytes());

                System.out.println("Hash stored successfully.");

            } else {

                String storedHash =
                        new String(Files.readAllBytes(Paths.get(hashFile)));

                if (currentHash.equals(storedHash.trim())) {
                    System.out.println("✓ File Integrity Verified");
                } else {
                    System.out.println("✗ File Modified");
                }
            }

        } catch (Exception e) {
            System.out.println("Error: " + e.getMessage());
        }
    }
}
